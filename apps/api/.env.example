PORT=3001
APP_ENV=development
CORS_ALLOWED_ORIGINS=http://localhost:3000
SQLITE_DB_PATH=./data/wstprtradio.db
STATION_NAME=West Port Radio

# Cookie session signing key. Generate with: openssl rand -hex 32
# Required in production; auto-generated for development if unset.
SESSION_SECRET=

# Admin users for /admin/* cookie session login.
# Format: username:password,username:password
# Default in development is marco:barkbark,mun:woofwoof.
# In production this MUST be set via `fly secrets set` and never committed.
ADMIN_USERS=

# Set to "true" to allow LAN-wide CORS in development (any 10.*, 172.16-31.*,
# 192.168.*, *.local origin). Defaults to localhost-only for safety.
CORS_DEV_LAN=
