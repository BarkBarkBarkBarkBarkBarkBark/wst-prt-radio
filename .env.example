# ═══════════════════════════════════════════════════════════════
#  West Port Radio — Environment Variables Reference
#
#  Copy this file to .env (repo root) and fill in your values.
#  App-specific files:
#    apps/web/.env.local  ← Next.js public + server vars
#    apps/api/.env        ← Fastify API vars
# ═══════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────
#  SHARED / META
# ───────────────────────────────────────────────────────────────
APP_ENV=development               # development | production

# ───────────────────────────────────────────────────────────────
#  FRONTEND  (apps/web — Next.js on Vercel)
#  All NEXT_PUBLIC_* vars are baked into the client bundle at
#  build time. Do NOT put secrets here.
# ───────────────────────────────────────────────────────────────

# Base URL of the Fastify API (no trailing slash)
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001

# Canonical public site URL (used for OG tags, redirects, etc.)
NEXT_PUBLIC_PUBLIC_SITE_URL=http://localhost:3000

# Direct radio stream URL served by AzuraCast / Icecast.
# If omitted, the player derives it from NEXT_PUBLIC_API_BASE_URL.
NEXT_PUBLIC_STREAM_URL=https://radio.wstprtradio.com/radio.mp3

# ───────────────────────────────────────────────────────────────
#  BACKEND  (apps/api — Fastify on Fly.io)
# ───────────────────────────────────────────────────────────────

# TCP port the Fastify server listens on
PORT=3001

# Session signing secret — must be ≥32 random characters in production
SESSION_SECRET=change_me_32_chars_minimum_secret

# AES-256 encryption key for sensitive DB fields (64 hex chars = 32 bytes)
# Generate with: openssl rand -hex 32
BACKEND_ENCRYPTION_KEY=REPLACE_WITH_RANDOM_64_HEX_CHARS

# Absolute path to the SQLite database file (Fly.io persistent volume)
SQLITE_DB_PATH=/data/wstprtradio.db

# Seed credentials for the first admin account (applied on first boot)
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_me_on_first_login

# ───────────────────────────────────────────────────────────────
#  AZURACAST  (self-hosted radio station backend)
# ───────────────────────────────────────────────────────────────

# AzuraCast admin panel URL (your VM, NOT Vercel/Fly)
AZURACAST_BASE_URL=https://azura-admin.wstprtradio.com

# Public-facing MP3 stream URL (served by AzuraCast/Icecast)
AZURACAST_PUBLIC_STREAM_URL=https://radio.wstprtradio.com/radio.mp3

# Public AzuraCast API base URL (for now-playing metadata)
AZURACAST_PUBLIC_API_URL=https://radio.wstprtradio.com/api

# AzuraCast API key — generate in AzuraCast → My Account → API Keys
AZURACAST_API_KEY=

# Numeric station ID shown in the AzuraCast station URL (usually 1)
AZURACAST_STATION_ID=1

# ───────────────────────────────────────────────────────────────
#  CLOUDFLARE STREAM  (live video broadcasting)
# ───────────────────────────────────────────────────────────────

# Cloudflare account ID (visible in the dashboard sidebar)
CLOUDFLARE_ACCOUNT_ID=

# API token with "Stream: Edit" permission
CLOUDFLARE_STREAM_API_TOKEN=

# Live Input ID created in Cloudflare Stream for ingest
CLOUDFLARE_LIVE_INPUT_ID=

# ───────────────────────────────────────────────────────────────
#  NOTIFICATIONS
# ───────────────────────────────────────────────────────────────

# Discord webhook URL for show-start / error alerts (optional)
DISCORD_WEBHOOK_URL=
